---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>26AJ クラス分け判定</title>
    <meta name="description" content="履修登録のクラス分けを自動判定します。" />
    
    <!-- Open Graph -->
    <meta property="og:title" content="26AJ クラス分け判定" />
    <meta property="og:description" content="履修登録のクラス分けを自動判定します。" />
    <meta property="og:type" content="website" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="26AJ クラス分け判定" />
    <meta name="twitter:description" content="履修登録のクラス分けを自動判定します。" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
      html {
        scrollbar-gutter: stable;
      }
      
      body {
        font-family: 'Inter', 'Noto Sans JP', sans-serif;
      }
    </style>
  </head>
  <body class="bg-white min-h-screen">
    <!-- Header -->
    <header class="py-6 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto text-center">
        <h1 class="text-xl font-medium text-gray-900">
          26AJ クラス分け判定
        </h1>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Input Section -->
      <div class="mb-8 flex justify-center">
        <div class="w-full max-w-xs">
          <label for="studentNumber" class="block text-sm font-medium text-gray-700 mb-2">
            学籍番号末尾3桁
          </label>
          <input
            type="number"
            id="studentNumber"
            class="w-full px-4 py-2 text-base border border-gray-300 rounded focus:outline-none focus:border-gray-900 focus:ring-1 focus:ring-gray-900"
            placeholder="例: 123"
            min="1"
            max="999"
            autocomplete="off"
          />
          <div id="errorMessage" class="hidden mt-2 text-sm text-gray-700"></div>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="hidden space-y-12"></div>
    </main>

    <script>
      import { classifyStudent, validateStudentNumber } from '../utils/classification';
      import type { ClassInfo, SemesterClasses } from '../types';

      const inputField = document.getElementById('studentNumber') as HTMLInputElement;
      const errorMessage = document.getElementById('errorMessage') as HTMLDivElement;
      const resultsContainer = document.getElementById('results') as HTMLDivElement;

      function createClassCard(classInfo: ClassInfo): string {
        return `
          <div class="border border-gray-200 rounded-lg p-5">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">
              ${classInfo.subject}
            </h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">曜日・時限</span>
                <span class="text-gray-900 font-medium">${classInfo.dayTime}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">教員</span>
                <span class="text-gray-900 font-medium">${classInfo.teacher}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">教室</span>
                <span class="text-gray-900 font-medium">${classInfo.classroom}</span>
              </div>
            </div>
          </div>
        `;
      }

      function createSemesterSection(semesterData: SemesterClasses): string {
        const cardsHtml = semesterData.classes.map(createClassCard).join('');
        
        return `
          <div class="semester-section">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              ${semesterData.semester}
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              ${cardsHtml}
            </div>
          </div>
        `;
      }

      function handleInput() {
        const value = inputField.value;
        
        // 空の場合は結果を非表示
        if (!value.trim()) {
          errorMessage.classList.add('hidden');
          resultsContainer.classList.add('hidden');
          return;
        }

        const validation = validateStudentNumber(value);

        if (!validation.isValid) {
          errorMessage.textContent = validation.error || '';
          errorMessage.classList.remove('hidden');
          resultsContainer.classList.add('hidden');
          return;
        }

        // 入力が有効な場合
        errorMessage.classList.add('hidden');
        const semesterGroups = classifyStudent(validation.number!);
        
        // 結果を表示
        resultsContainer.innerHTML = semesterGroups.map(createSemesterSection).join('');
        resultsContainer.classList.remove('hidden');
      }

      // リアルタイム判定
      inputField.addEventListener('input', handleInput);
    </script>
  </body>
</html>
